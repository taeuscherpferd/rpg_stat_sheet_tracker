{
  "name": "rlrpg",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @rlrpg/backend --filter @rlrpg/frontend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "deploy:homelab:check": "bash scripts/homelab/deploy.sh check",
    "deploy:homelab": "bash scripts/homelab/deploy.sh deploy",
    "deploy:homelab:setup": "bash scripts/homelab/deploy.sh setup"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
